{
  "name": "wbgl-ui-governance",
  "private": true,
  "version": "1.0.0",
  "description": "WBGL UI governance E2E smoke tests",
  "scripts": {
    "i18n:i1": "php app/Scripts/i18n-static-scan.php scan && node app/Scripts/i18n-runtime-harvest.mjs && php app/Scripts/i18n-catalog-merge.php",
    "i18n:static-scan": "php app/Scripts/i18n-static-scan.php scan",
    "i18n:quality-scan": "php app/Scripts/i18n-quality-gate.php scan",
    "i18n:quality-gate": "php app/Scripts/i18n-quality-gate.php gate",
    "i18n:runtime-harvest": "node app/Scripts/i18n-runtime-harvest.mjs",
    "i18n:catalog-merge": "php app/Scripts/i18n-catalog-merge.php",
    "i18n:keygen": "php app/Scripts/i18n-keygen.php",
    "i18n:sync-locales": "php app/Scripts/i18n-sync-locales.php sync",
    "i18n:sync-check": "php app/Scripts/i18n-sync-locales.php check",
    "i18n:fill-ar-from-en": "python app/Scripts/i18n-fill-ar-from-en.py",
    "i18n:i2": "npm run i18n:keygen && npm run i18n:sync-locales && npm run i18n:sync-check",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
